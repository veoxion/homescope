# Homescope Backend 환경 변수
# 이 파일을 .env로 복사하여 사용하세요.
# cp .env.example .env

# PostgreSQL 연결 URL (Docker Compose 사용 시 포트 5433)
# connection_limit: 커넥션 풀 크기 (기본 num_cpus * 2 + 1)
# pool_timeout: 커넥션 대기 타임아웃 초 (기본 10)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/homescope?connection_limit=10&pool_timeout=10"

# 국토교통부 실거래 공공데이터 API 키 (https://www.data.go.kr)
MOLIT_API_KEY=""

# 카카오 REST API 키 - 지오코딩용 (https://developers.kakao.com)
KAKAO_API_KEY=""

# 서버 포트
PORT=3000

# 실행 환경
NODE_ENV=development

# CORS 허용 Origin (콤마 구분으로 여러 개 가능)
CORS_ORIGIN=http://localhost:3001

# 관리자 API 키 (데이터 파이프라인, CUD 엔드포인트 보호)
ADMIN_API_KEY=

# Redis 연결 (작업 큐용, 선택적 - 미설정 시 큐 비활성화)
REDIS_HOST=localhost
REDIS_PORT=6379
